{
	"name": "pl_bronze_silver_data_load",
	"properties": {
		"activities": [
			{
				"name": "Lookup_bronze_silver_control_tab",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 3,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "SqlServerSource",
						"sqlReaderQuery": {
							"value": "@concat(\n    'SELECT * FROM [',\n    pipeline().parameters.pPlSchemaName,\n    '].[', \n    pipeline().parameters.pPlSchemaName,\n    '] WHERE Enabled = ''True'''\n)",
							"type": "Expression"
						},
						"queryTimeout": "00:03:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "ds_sqlserver_source_table_param",
						"type": "DatasetReference",
						"parameters": {
							"pDsSourceServerName": {
								"value": "@pipeline().parameters.pPlServerName",
								"type": "Expression"
							},
							"pDsSourceDatabasename": {
								"value": "@pipeline().parameters.pPlDatabaseName",
								"type": "Expression"
							},
							"pDsSourceSchemaName": {
								"value": "@pipeline().parameters.pPlSchemaName",
								"type": "Expression"
							},
							"pDsSourceTableName": {
								"value": "@pipeline().parameters.pPTableName",
								"type": "Expression"
							}
						}
					}
				}
			}
		],
		"parameters": {
			"pPlServerName": {
				"type": "string",
				"defaultValue": "localhost\\SQLEXPRESS"
			},
			"pPlDatabaseName": {
				"type": "string",
				"defaultValue": "dev_clintrail_edc_src"
			},
			"pPlSchemaName": {
				"type": "string",
				"defaultValue": "edcsrcmetadata"
			},
			"pPTableName": {
				"type": "string",
				"defaultValue": "srcEdcBronzeToSilverControl"
			}
		},
		"folder": {
			"name": "dev_clintrail/bronze_silver_load"
		},
		"annotations": []
	}
}